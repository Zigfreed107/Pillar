<!--
    SelectModeOverlay.xaml
    Defines the viewport overlay shown while selection mode is active.
-->
<UserControl x:Class="Pillar.UI.Modes.SelectModeOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource ModeOverlayPanelStyle}">
        <StackPanel>
            <TextBlock Style="{StaticResource ModeOverlayTitleTextStyle}"
                       Text="Select" />
            <TextBlock Style="{StaticResource ModeOverlayBodyTextStyle}"
                       Text="Click an entity to select it. Drag across the viewer to window-select." />
            <Separator Margin="0,10,0,8" />
            <TextBlock Style="{StaticResource ModeOverlayBodyTextStyle}"
                       Text="Shift adds to selection. Ctrl removes from selection. Escape returns here." />
        </StackPanel>
    </Border>
</UserControl>

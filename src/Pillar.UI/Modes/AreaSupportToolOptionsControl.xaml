<!--
    AreaSupportToolOptionsControl.xaml
    Defines the self-contained Area Support tool options overlay panel shown when the Area Support operation is active.
-->
<UserControl x:Class="Pillar.UI.Modes.AreaSupportToolOptionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Pillar.UI.Controls">
    <Border Style="{StaticResource ViewportOverlayPanelStyle}">
        <StackPanel>
            <TextBlock Style="{StaticResource ModeOverlayTitleTextStyle}"
                       Text="Select faces to support" />

            <Grid Margin="0,14,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="34" />
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        MinHeight="30"
                        HorizontalAlignment="Stretch"
                        Click="SelectFacesButton_Click"
                        Content="Select faces" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,12,8,0"
                           Style="{StaticResource ModeOverlayLabelTextStyle}"
                           Text="Spacing" />
                <controls:NumericUpDown x:Name="AreaSpacingNumericUpDown"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,8,0,0"
                                        MinWidth="104"
                                        Minimum="0"
                                        Increment="1"
                                        DecimalPlaces="1"
                                        Value="3.0"
                                        ValueChanged="AreaOption_ValueChanged" />
                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Margin="8,12,0,0"
                           Style="{StaticResource ModeOverlayBodyTextStyle}"
                           Text="mm" />

                <ToggleButton x:Name="ShowSupportSpacingToggleButton"
                              Grid.Row="2"
                              Grid.Column="0"
                              Grid.ColumnSpan="3"
                              MinHeight="30"
                              Margin="0,12,0,0"
                              HorizontalAlignment="Stretch"
                              Checked="ShowSupportSpacingToggleButton_Changed"
                              Unchecked="ShowSupportSpacingToggleButton_Changed"
                              Content="Show support spacing" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,12,8,0"
                           Style="{StaticResource ModeOverlayLabelTextStyle}"
                           Text="Boundary offset" />
                <controls:NumericUpDown x:Name="BoundaryOffsetNumericUpDown"
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Margin="0,8,0,0"
                                        MinWidth="104"
                                        Minimum="0"
                                        Increment="0.1"
                                        DecimalPlaces="1"
                                        Value="1.5"
                                        ValueChanged="AreaOption_ValueChanged" />
                <TextBlock Grid.Row="3"
                           Grid.Column="2"
                           Margin="8,12,0,0"
                           Style="{StaticResource ModeOverlayBodyTextStyle}"
                           Text="mm" />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,12,8,0"
                           Style="{StaticResource ModeOverlayLabelTextStyle}"
                           Text="Boundary spacing" />
                <controls:NumericUpDown x:Name="BoundarySpacingNumericUpDown"
                                        Grid.Row="4"
                                        Grid.Column="1"
                                        Margin="0,8,0,0"
                                        MinWidth="104"
                                        Minimum="0"
                                        Increment="0.1"
                                        DecimalPlaces="1"
                                        Value="2.4"
                                        ValueChanged="AreaOption_ValueChanged" />
                <TextBlock Grid.Row="4"
                           Grid.Column="2"
                           Margin="8,12,0,0"
                           Style="{StaticResource ModeOverlayBodyTextStyle}"
                           Text="mm" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Margin="0,12,8,0"
                           Style="{StaticResource ModeOverlayLabelTextStyle}"
                           Text="Concave angle" />
                <controls:NumericUpDown x:Name="ConcaveCornerAngleNumericUpDown"
                                        Grid.Row="5"
                                        Grid.Column="1"
                                        Margin="0,8,0,0"
                                        MinWidth="104"
                                        Minimum="0"
                                        Maximum="180"
                                        Increment="1"
                                        DecimalPlaces="0"
                                        Value="30"
                                        ValueChanged="AreaOption_ValueChanged" />
                <TextBlock Grid.Row="5"
                           Grid.Column="2"
                           Margin="8,12,0,0"
                           Style="{StaticResource ModeOverlayBodyTextStyle}"
                           Text="deg" />

                <StackPanel Grid.Row="6"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,12,0,0"
                            Orientation="Horizontal">
                    <RadioButton x:Name="HexGridFillRadioButton"
                                 VerticalAlignment="Center"
                                 GroupName="AreaSupportFillMode"
                                 IsChecked="True"
                                 Checked="FillModeRadioButton_Checked"
                                 Content="Hex grid" />
                    <RadioButton x:Name="BoundaryOffsetsFillRadioButton"
                                 Margin="18,0,0,0"
                                 VerticalAlignment="Center"
                                 GroupName="AreaSupportFillMode"
                                 Checked="FillModeRadioButton_Checked"
                                 Content="Boundary offsets" />
                </StackPanel>

                <CheckBox x:Name="SupportThinRegionsCheckBox"
                          Grid.Row="7"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          Margin="0,12,0,0"
                          VerticalAlignment="Center"
                          Checked="SupportThinRegionsCheckBox_Changed"
                          Unchecked="SupportThinRegionsCheckBox_Changed"
                          Content="Support thin regions"
                          IsChecked="True" />

                <TextBlock x:Name="MinimumThinRegionThicknessLabel"
                           Grid.Row="8"
                           Grid.Column="0"
                           Margin="0,12,8,0"
                           Style="{StaticResource ModeOverlayLabelTextStyle}"
                           Text="Minimum thickness" />
                <controls:NumericUpDown x:Name="MinimumThinRegionThicknessNumericUpDown"
                                        Grid.Row="8"
                                        Grid.Column="1"
                                        Margin="0,8,0,0"
                                        MinWidth="104"
                                        Minimum="0"
                                        Increment="0.1"
                                        DecimalPlaces="1"
                                        Value="1.0"
                                        ValueChanged="AreaOption_ValueChanged" />
                <TextBlock x:Name="MinimumThinRegionThicknessUnitLabel"
                           Grid.Row="8"
                           Grid.Column="2"
                           Margin="8,12,0,0"
                           Style="{StaticResource ModeOverlayBodyTextStyle}"
                           Text="mm" />

                <TextBlock x:Name="AdditionalOffsetCountLabel"
                           Grid.Row="10"
                           Grid.Column="0"
                           Margin="0,12,8,0"
                           Style="{StaticResource ModeOverlayLabelTextStyle}"
                           Text="Number of offsets"
                           Visibility="Collapsed" />
                <controls:NumericUpDown x:Name="AdditionalOffsetCountNumericUpDown"
                                        Grid.Row="10"
                                        Grid.Column="1"
                                        Margin="0,8,0,0"
                                        MinWidth="104"
                                        Minimum="0"
                                        Increment="1"
                                        DecimalPlaces="0"
                                        ValueChanged="AreaOption_ValueChanged"
                                        Visibility="Collapsed" />

                <TextBlock x:Name="OffsetSpacingLabel"
                           Grid.Row="9"
                           Grid.Column="0"
                           Margin="0,12,8,0"
                           Style="{StaticResource ModeOverlayLabelTextStyle}"
                           Text="Offset spacing"
                           Visibility="Collapsed" />
                <controls:NumericUpDown x:Name="OffsetSpacingNumericUpDown"
                                        Grid.Row="9"
                                        Grid.Column="1"
                                        Margin="0,8,0,0"
                                        MinWidth="104"
                                        Minimum="0"
                                        Increment="0.1"
                                        DecimalPlaces="1"
                                        Value="1.5"
                                        ValueChanged="AreaOption_ValueChanged"
                                        Visibility="Collapsed" />
                <TextBlock x:Name="OffsetSpacingUnitLabel"
                           Grid.Row="9"
                           Grid.Column="2"
                           Margin="8,12,0,0"
                           Style="{StaticResource ModeOverlayBodyTextStyle}"
                           Text="mm"
                           Visibility="Collapsed" />

                <Button x:Name="DeleteSelectedSupportsButton"
                        Grid.Row="11"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        MinHeight="30"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Stretch"
                        Click="DeleteSelectedSupportsButton_Click"
                        Content="Delete"
                        IsEnabled="False" />

                <Grid Grid.Row="12"
                      Grid.Column="0"
                      Grid.ColumnSpan="3"
                      Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            MinHeight="30"
                            HorizontalAlignment="Stretch"
                            Click="ApplyAreaSupportButton_Click"
                            Content="Apply" />
                    <Button Grid.Column="2"
                            MinHeight="30"
                            HorizontalAlignment="Stretch"
                            Click="CloseAreaSupportButton_Click"
                            Content="Close" />
                </Grid>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>

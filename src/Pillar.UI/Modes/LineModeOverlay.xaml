<!--
    LineModeOverlay.xaml
    Defines the viewport overlay shown while line drawing mode is active.
-->
<UserControl x:Class="Pillar.UI.Modes.LineModeOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource ModeOverlayPanelStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Style="{StaticResource ModeOverlayTitleTextStyle}"
                       Text="Line" />
            <TextBlock Grid.Row="2"
                       Style="{StaticResource ModeOverlayBodyTextStyle}"
                       Text="Click once for the start point, then click again for the end point." />
            <StackPanel Grid.Row="4">
                <TextBlock Style="{StaticResource ModeOverlayLabelTextStyle}"
                           Text="Snapping" />
                <TextBlock Margin="0,2,0,0"
                           Style="{StaticResource ModeOverlayBodyTextStyle}"
                           Text="Endpoint and midpoint candidates are used when available." />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

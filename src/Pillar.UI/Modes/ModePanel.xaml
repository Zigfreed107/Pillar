<!--
    ModePanel.xaml
    Defines the always-visible ribbon-style workflow panel that sits beside the layer panel and previews high-level mode and tool organization.
-->
<UserControl x:Class="Pillar.UI.Modes.ModePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             MinWidth="340">
    <UserControl.Resources>
        <Style x:Key="ModePanelToolButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="MinHeight" Value="84" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="ModePanelToolToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="MinHeight" Value="84" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="ModePanelToolTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ModePanelToolDescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource ModeOverlayBodyBrush}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ModePanelImportPromptStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasImportedModels}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModePanelSelectionPromptStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasImportedModels}" Value="True" />
                        <Condition Binding="{Binding CanShowWorkflowTabs}" Value="False" />
                        <Condition Binding="{Binding HasSelectedModelLayer}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModePanelTabsStyle" TargetType="TabControl">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasImportedModels}" Value="True" />
                        <Condition Binding="{Binding CanShowWorkflowTabs}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModePanelSupportToolsStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasMultipleSelectedModels}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModePanelSupportMultiSelectionPromptStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasMultipleSelectedModels}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource LayerOverlayPanelStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource ModePanelImportPromptStyle}">
                <TextBlock Style="{StaticResource ModeOverlayTitleTextStyle}"
                           Text="Mode Panel" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource ModeOverlayBodyTextStyle}"
                           Text="Import a model first to unlock transform and support workflows." />
            </StackPanel>

            <StackPanel Grid.Row="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource ModePanelSelectionPromptStyle}">
                <TextBlock Style="{StaticResource ModeOverlayTitleTextStyle}"
                           Text="Mode Panel" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource ModeOverlayBodyTextStyle}"
                           Text="Select a model in the Layers panel before editing it or adding supports." />
            </StackPanel>

            <TabControl Grid.Row="0"
                        Style="{StaticResource ModePanelTabsStyle}">
                <TabItem>
                    <TabItem.Header>
                        <TextBlock FontWeight="SemiBold"
                                   Text="Transform" />
                    </TabItem.Header>

                    <StackPanel Margin="0,10,0,0">

                        <primitives:UniformGrid Margin="0,0,0,0"
                                                Columns="3">
                            <Button Style="{StaticResource ModePanelToolButtonStyle}"
                                    Click="TranslateButton_Click">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource ModePanelToolTitleTextStyle}"
                                               Text="Translate" />
                                    <TextBlock Style="{StaticResource ModePanelToolDescriptionTextStyle}"
                                               Text="Move the active model in space" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ModePanelToolButtonStyle}"
                                    Click="RotateButton_Click">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource ModePanelToolTitleTextStyle}"
                                               Text="Rotate" />
                                    <TextBlock Style="{StaticResource ModePanelToolDescriptionTextStyle}"
                                               Text="Adjust orientation to reduce overhangs" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ModePanelToolButtonStyle}"
                                    Click="ScaleButton_Click">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource ModePanelToolTitleTextStyle}"
                                               Text="Scale" />
                                    <TextBlock Style="{StaticResource ModePanelToolDescriptionTextStyle}"
                                               Text="Resize the imported model uniformly" />
                                </StackPanel>
                            </Button>
                        </primitives:UniformGrid>
                    </StackPanel>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <TextBlock FontWeight="SemiBold"
                                   Text="Supports" />
                    </TabItem.Header>

                    <Grid Margin="0,12,0,0">
                        <StackPanel Style="{StaticResource ModePanelSupportToolsStyle}">
                            <TextBlock Style="{StaticResource ModeOverlayLabelTextStyle}"
                                       Text="Support Creation" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource ModeOverlayBodyTextStyle}"
                                       Text="These buttons preview how manual support operations will live inside the ribbon-style workflow panel." />

                            <primitives:UniformGrid Margin="0,10,0,0"
                                                    Columns="3">
                                <ToggleButton x:Name="PointSupportButton"
                                              Style="{StaticResource ModePanelToolToggleButtonStyle}"
                                              Checked="PointSupportButton_Checked"
                                              Unchecked="PointSupportButton_Unchecked">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource ModePanelToolTitleTextStyle}"
                                                   Text="Point" />
                                        <TextBlock Style="{StaticResource ModePanelToolDescriptionTextStyle}"
                                                   Text="Place a single support at a picked point" />
                                    </StackPanel>
                                </ToggleButton>

                                <Button Style="{StaticResource ModePanelToolButtonStyle}"
                                        Click="LineSupportButton_Click">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource ModePanelToolTitleTextStyle}"
                                                   Text="Line" />
                                        <TextBlock Style="{StaticResource ModePanelToolDescriptionTextStyle}"
                                                   Text="Create a row of supports between two picks" />
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ModePanelToolButtonStyle}"
                                        Click="CircleSupportButton_Click">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource ModePanelToolTitleTextStyle}"
                                                   Text="Circle" />
                                        <TextBlock Style="{StaticResource ModePanelToolDescriptionTextStyle}"
                                                   Text="Distribute supports around a circular region" />
                                    </StackPanel>
                                </Button>
                            </primitives:UniformGrid>
                        </StackPanel>

                        <StackPanel VerticalAlignment="Center"
                                    Style="{StaticResource ModePanelSupportMultiSelectionPromptStyle}">
                            <TextBlock Style="{StaticResource ModeOverlayLabelTextStyle}"
                                       Text="Support Creation" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource ModeOverlayBodyTextStyle}"
                                       Text="Select one model only before adding supports." />
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>

<!--
    LineSupportToolOptionsControl.xaml
    Defines the self-contained Line Support tool options overlay panel shown when the Line Support operation is active.
-->
<UserControl x:Class="Pillar.UI.Modes.LineSupportToolOptionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Pillar.UI.Controls">
    <Border Style="{StaticResource ViewportOverlayPanelStyle}">
        <StackPanel>
            <TextBlock Style="{StaticResource ModeOverlayTitleTextStyle}"
                       Text="Line Support Options" />

            <Grid Margin="0,14,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="36" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,4,8,0"
                           Style="{StaticResource ModeOverlayLabelTextStyle}"
                           Text="Spacing" />
                <controls:NumericUpDown x:Name="LineSupportSpacingNumericUpDown"
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        MinWidth="104"
                                        Minimum="0.25"
                                        Increment="0.25"
                                        DecimalPlaces="2"
                                        Value="3.00"
                                        ValueChanged="LineSupportSpacingNumericUpDown_ValueChanged" />
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Margin="8,4,0,0"
                           Style="{StaticResource ModeOverlayBodyTextStyle}"
                           Text="mm" />

                <Button x:Name="DeleteSelectedSupportsButton"
                        Grid.Row="1"
                        Grid.Column="1"
                        MinHeight="30"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Stretch"
                        Click="DeleteSelectedSupportsButton_Click"
                        Content="Delete"
                        IsEnabled="False" />

                <Grid Grid.Row="2"
                      Grid.Column="0"
                      Grid.ColumnSpan="3"
                      Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            MinHeight="30"
                            HorizontalAlignment="Stretch"
                            Click="ApplyLineSupportButton_Click"
                            Content="Apply" />
                    <Button Grid.Column="2"
                            MinHeight="30"
                            HorizontalAlignment="Stretch"
                            Click="CloseLineSupportButton_Click"
                            Content="Close" />
                </Grid>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>

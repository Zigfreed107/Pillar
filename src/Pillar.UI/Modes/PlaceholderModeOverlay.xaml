<!--
    PlaceholderModeOverlay.xaml
    Defines a reusable overlay for planned modes that are visible but not yet implemented.
-->
<UserControl x:Class="Pillar.UI.Modes.PlaceholderModeOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource ModeOverlayPanelStyle}">
        <StackPanel>
            <TextBlock Style="{StaticResource ModeOverlayTitleTextStyle}"
                       Text="{Binding ModeName, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <TextBlock Style="{StaticResource ModeOverlayBodyTextStyle}"
                       Text="{Binding Message, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </StackPanel>
    </Border>
</UserControl>

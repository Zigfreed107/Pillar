<!--
    FaceSetSelectionToolPanel.xaml
    Provides the floating controls for temporary mesh-face selection sessions launched by client tools.
-->
<UserControl x:Class="Pillar.UI.Modes.FaceSetSelectionToolPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Pillar.UI.Controls"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             MinWidth="360"
             IsHitTestVisible="True">
    <Border Padding="10"
            Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
            BorderThickness="1"
            CornerRadius="4"
            SnapsToDevicePixels="True">
        <StackPanel>
            <DockPanel Margin="0,0,0,8">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="Face Set Selection" />
                <TextBlock x:Name="SelectionCountTextBlock"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Text="0 faces" />
            </DockPanel>

            <StackPanel Margin="0,0,0,8"
                        Orientation="Horizontal">
                <ToggleButton x:Name="SelectToolButton"
                              MinWidth="72"
                              Margin="0,0,4,0"
                              Padding="8,3"
                              Content="Select"
                              Click="SelectToolButton_Click" />
                <ToggleButton x:Name="LineSelectToolButton"
                              MinWidth="88"
                              Margin="0,0,4,0"
                              Padding="8,3"
                              Content="Line Select"
                              Click="LineSelectToolButton_Click" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ToggleButton x:Name="AngleSelectToolButton"
                                  Grid.Column="0"
                                  MinWidth="92"
                                  Padding="8,3"
                                  Content="Angle Select"
                                  Click="AngleSelectToolButton_Click" />
                    <ToggleButton x:Name="AngleSelectSettingsButton"
                                  Grid.Column="1"
                                  Width="26"
                                  Margin="2,0,0,0"
                                  Padding="0"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  Content="&#xE70D;"
                                  FontFamily="Segoe Fluent Icons"
                                  Click="AngleSelectSettingsButton_Click" />

                    <primitives:Popup x:Name="AngleSelectSettingsPopup"
                                      AllowsTransparency="True"
                                      Placement="Bottom"
                                      PlacementTarget="{Binding ElementName=AngleSelectSettingsButton}"
                                      StaysOpen="False"
                                      Closed="AngleSelectSettingsPopup_Closed">
                        <Border MinWidth="190"
                                Padding="10"
                                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1"
                                SnapsToDevicePixels="True">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,6"
                                           Text="Coplanar threshold" />
                                <DockPanel LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Right"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="&#x00B0;" />
                                    <controls:NumericUpDown x:Name="CoplanarThresholdNumericUpDown"
                                                            Width="116"
                                                            Minimum="0"
                                                            Maximum="180"
                                                            Increment="1"
                                                            DecimalPlaces="0"
                                                            Value="15"
                                                            ValueChanged="CoplanarThresholdNumericUpDown_ValueChanged" />
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </primitives:Popup>
                </Grid>
            </StackPanel>

            <DockPanel>
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal">
                    <ToggleButton x:Name="AddModifierButton"
                                  Width="32"
                                  Margin="0,0,4,0"
                                  Padding="0,3"
                                  Content="+"
                                  Click="AddModifierButton_Click" />
                    <ToggleButton x:Name="RemoveModifierButton"
                                  Width="32"
                                  Margin="0,0,8,0"
                                  Padding="0,3"
                                  Content="-"
                                  Click="RemoveModifierButton_Click" />
                    <Button MinWidth="56"
                            Margin="0,0,4,0"
                            Padding="8,3"
                            Content="Clear"
                            Click="ClearButton_Click" />
                    <Button x:Name="UndoFaceSelectionButton"
                            MinWidth="34"
                            Margin="0,0,4,0"
                            Padding="8,3"
                            Content="Undo"
                            Click="UndoButton_Click" />
                    <Button x:Name="RedoFaceSelectionButton"
                            MinWidth="34"
                            Padding="8,3"
                            Content="Redo"
                            Click="RedoButton_Click" />
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        MinWidth="56"
                        Padding="10,3"
                        Content="OK"
                        Click="OkButton_Click" />
            </DockPanel>

            <TextBlock x:Name="ToolPromptTextBlock"
                       Margin="0,8,0,0"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Text="Click on a face"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>

<!--
    SupportClusterToolOptionsControl.xaml
    Presents support Cluster modifier parameters in the Tool Options panel.
-->
<UserControl x:Class="Pillar.UI.Modes.SupportClusterToolOptionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="280">
    <Border Style="{StaticResource ViewportOverlayPanelStyle}">
        <StackPanel>
            <TextBlock Style="{StaticResource ModeOverlayTitleTextStyle}"
                       Text="Cluster Supports" />

            <TextBlock Margin="0,10,0,0"
                       Style="{StaticResource ModeOverlayLabelTextStyle}"
                       Text="Maximum Cluster Radius" />
            <TextBox x:Name="MaximumClusterRadiusTextBox"
                     Margin="0,4,0,0"
                     Text="4.00"
                     TextChanged="AnyOption_Changed" />

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource ModeOverlayLabelTextStyle}"
                               Text="Minimum Supports" />
                    <TextBox x:Name="MinimumSupportsTextBox"
                             Margin="0,4,0,0"
                             Text="2"
                             TextChanged="AnyOption_Changed" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ModeOverlayLabelTextStyle}"
                               Text="Maximum Supports" />
                    <TextBox x:Name="MaximumSupportsTextBox"
                             Margin="0,4,0,0"
                             Text="6"
                             TextChanged="AnyOption_Changed" />
                </StackPanel>
            </Grid>

            <TextBlock Margin="0,10,0,0"
                       Style="{StaticResource ModeOverlayLabelTextStyle}"
                       Text="Maximum Branch Angle From Vertical" />
            <TextBox x:Name="MaximumBranchAngleTextBox"
                     Margin="0,4,0,0"
                     Text="30.00"
                     TextChanged="AnyOption_Changed" />

            <TextBlock Margin="0,10,0,0"
                       Style="{StaticResource ModeOverlayLabelTextStyle}"
                       Text="Stem Sizing" />
            <ComboBox x:Name="StemSizingComboBox"
                      Margin="0,4,0,0"
                      SelectedIndex="0"
                      SelectionChanged="StemSizingComboBox_SelectionChanged">
                <ComboBoxItem Content="Automatic" />
                <ComboBoxItem Content="Manual" />
            </ComboBox>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource ModeOverlayLabelTextStyle}"
                               Text="Central Stem Bottom Diameter" />
                    <TextBox x:Name="CentralStemBottomDiameterTextBox"
                             Margin="0,4,0,0"
                             Text="1.00"
                             TextChanged="AnyOption_Changed" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ModeOverlayLabelTextStyle}"
                               Text="Central Stem Top Diameter" />
                    <TextBox x:Name="CentralStemTopDiameterTextBox"
                             Margin="0,4,0,0"
                             Text="0.75"
                             TextChanged="AnyOption_Changed" />
                </StackPanel>
            </Grid>

            <TextBlock Margin="0,10,0,0"
                       Style="{StaticResource ModeOverlayLabelTextStyle}"
                       Text="Cluster Branch Diameter" />
            <TextBox x:Name="ClusterBranchDiameterTextBox"
                     Margin="0,4,0,0"
                     Text="0.75"
                     TextChanged="AnyOption_Changed" />

            <CheckBox x:Name="PreviewCheckBox"
                      Margin="0,12,0,0"
                      IsChecked="True"
                      Content="Preview"
                      Checked="AnyOption_Changed"
                      Unchecked="AnyOption_Changed" />

            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,10,0,0"
                       Style="{StaticResource ModeOverlayBodyTextStyle}"
                       TextWrapping="Wrap"
                       Text="No preview has been calculated yet." />

            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button x:Name="ApplyToSelectedButton"
                        Grid.Row="0"
                        Grid.Column="0"
                        Content="Apply to Selected"
                        Click="ApplyToSelectedButton_Click" />
                <Button x:Name="ApplyToAllButton"
                        Grid.Row="0"
                        Grid.Column="2"
                        Content="Apply to All"
                        Click="ApplyToAllButton_Click" />
                <Button x:Name="RemoveAllButton"
                        Grid.Row="2"
                        Grid.Column="0"
                        Content="Remove All"
                        IsEnabled="False"
                        Click="RemoveAllButton_Click" />
                <Button x:Name="UnclusterSelectedButton"
                        Grid.Row="2"
                        Grid.Column="2"
                        Content="Uncluster Selected"
                        IsEnabled="False"
                        Click="UnclusterSelectedButton_Click" />
                <Button Grid.Row="4"
                        Grid.ColumnSpan="3"
                        Content="Close"
                        Click="CloseButton_Click" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>

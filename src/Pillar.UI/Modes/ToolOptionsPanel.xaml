<!--
    ToolOptionsPanel.xaml
    Defines the active-tool options overlay that sits beside the Mode Panel and will host per-tool settings.
-->
<UserControl x:Class="Pillar.UI.Modes.ToolOptionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="240">
    <Border Style="{StaticResource LayerOverlayPanelStyle}">
        <StackPanel>
            <TextBlock Style="{StaticResource ModeOverlayTitleTextStyle}"
                       Text="Tool Options Panel" />

            <TextBlock Margin="0,12,0,0"
                       Style="{StaticResource ModeOverlayLabelTextStyle}"
                       Text="Selected Tool" />
            <TextBlock x:Name="SelectedToolNameTextBlock"
                       Margin="0,4,0,0"
                       Style="{StaticResource ModeOverlayBodyTextStyle}"
                       Text="No tool selected" />

            <TextBlock x:Name="SettingsSummaryTextBlock"
                       Margin="0,12,0,0"
                       Style="{StaticResource ModeOverlayBodyTextStyle}"
                       Text="Select the Circle Support tool to edit its available options." />

            <Grid x:Name="CircleSupportOptionsGrid"
                  Margin="0,14,0,0"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="36" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,4,8,0"
                           Style="{StaticResource ModeOverlayLabelTextStyle}"
                           Text="Spacing" />
                <TextBox x:Name="CircleSupportSpacingTextBox"
                         Grid.Row="0"
                         Grid.Column="1"
                         MinWidth="80"
                         Text="5.00" />
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Margin="8,4,0,0"
                           Style="{StaticResource ModeOverlayBodyTextStyle}"
                           Text="mm" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>

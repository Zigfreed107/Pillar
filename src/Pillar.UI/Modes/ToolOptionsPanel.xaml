<!--
    ToolOptionsPanel.xaml
    Defines the active-tool options overlay host that selects a focused options control for the current tool.
-->
<UserControl x:Class="Pillar.UI.Modes.ToolOptionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:modes="clr-namespace:Pillar.UI.Modes"
             MinWidth="240">
    <Border Style="{StaticResource ViewportOverlayPanelStyle}">
        <StackPanel>
            <TextBlock Style="{StaticResource ModeOverlayTitleTextStyle}"
                       Text="Tool Options Panel" />

            <TextBlock Margin="0,12,0,0"
                       Style="{StaticResource ModeOverlayLabelTextStyle}"
                       Text="Selected Tool" />
            <TextBlock x:Name="SelectedToolNameTextBlock"
                       Margin="0,4,0,0"
                       Style="{StaticResource ModeOverlayBodyTextStyle}"
                       Text="No tool selected" />

            <TextBlock x:Name="SettingsSummaryTextBlock"
                       Margin="0,12,0,0"
                       Style="{StaticResource ModeOverlayBodyTextStyle}"
                       Text="Select a tool to edit its available options." />

            <modes:RingSupportToolOptionsControl x:Name="RingSupportOptionsControl"
                                                 Margin="0,14,0,0"
                                                 Visibility="Collapsed" />
            <modes:ScaleToolOptionsControl x:Name="ScaleOptionsControl"
                                           Margin="0,14,0,0"
                                           Visibility="Collapsed" />
        </StackPanel>
    </Border>
</UserControl>

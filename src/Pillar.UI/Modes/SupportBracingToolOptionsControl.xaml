<!--
    SupportBracingToolOptionsControl.xaml
    Presents support Brace and Buttress modifier parameters in the Tool Options panel.
-->
<UserControl x:Class="Pillar.UI.Modes.SupportBracingToolOptionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="300">
    <Border Style="{StaticResource ViewportOverlayPanelStyle}">
        <StackPanel>
            <TextBlock Style="{StaticResource ModeOverlayTitleTextStyle}"
                       Text="Support Bracing" />

            <TextBlock Margin="0,10,0,0"
                       Style="{StaticResource ModeOverlayLabelTextStyle}"
                       Text="Bracing" />

            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource ModeOverlayLabelTextStyle}"
                               Text="Minimum Brace Angle" />
                    <TextBox x:Name="MinimumBraceAngleTextBox"
                             Margin="0,4,0,0"
                             Text="50"
                             TextChanged="AnyOption_Changed" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ModeOverlayLabelTextStyle}"
                               Text="Maximum Brace Angle" />
                    <TextBox x:Name="MaximumBraceAngleTextBox"
                             Margin="0,4,0,0"
                             Text="70"
                             TextChanged="AnyOption_Changed" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource ModeOverlayLabelTextStyle}"
                               Text="Maximum Brace Length" />
                    <TextBox x:Name="MaximumBraceLengthTextBox"
                             Margin="0,4,0,0"
                             Text="10"
                             TextChanged="AnyOption_Changed" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ModeOverlayLabelTextStyle}"
                               Text="Diameter" />
                    <TextBox x:Name="BraceDiameterTextBox"
                             Margin="0,4,0,0"
                             Text="0.75"
                             TextChanged="AnyOption_Changed" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button x:Name="BraceSelectedButton"
                        Grid.Row="0"
                        Grid.Column="0"
                        Content="Brace Selected"
                        Click="BraceSelectedButton_Click" />
                <Button x:Name="BraceAllButton"
                        Grid.Row="0"
                        Grid.Column="2"
                        Content="Brace All"
                        Click="BraceAllButton_Click" />
                <Button x:Name="RemoveBracingFromSelectedButton"
                        Grid.Row="2"
                        Grid.ColumnSpan="3"
                        Content="Remove Bracing From Selected"
                        IsEnabled="False"
                        Click="RemoveBracingFromSelectedButton_Click" />
                <Button x:Name="RemoveAllBracingButton"
                        Grid.Row="4"
                        Grid.ColumnSpan="3"
                        Content="Remove All Bracing"
                        IsEnabled="False"
                        Click="RemoveAllBracingButton_Click" />
            </Grid>

            <TextBlock Margin="0,14,0,0"
                       Style="{StaticResource ModeOverlayLabelTextStyle}"
                       Text="Buttress" />

            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource ModeOverlayLabelTextStyle}"
                               Text="Buttress supports taller than" />
                    <TextBox x:Name="MinimumButtressHeightTextBox"
                             Margin="0,4,0,0"
                             Text="10"
                             TextChanged="AnyOption_Changed" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ModeOverlayLabelTextStyle}"
                               Text="Buttress spacing" />
                    <TextBox x:Name="ButtressSpacingTextBox"
                             Margin="0,4,0,0"
                             Text="2"
                             TextChanged="AnyOption_Changed" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button x:Name="ButtressSelectedButton"
                        Grid.Row="0"
                        Grid.Column="0"
                        Content="Buttress Selected"
                        Click="ButtressSelectedButton_Click" />
                <Button x:Name="ButtressAllButton"
                        Grid.Row="0"
                        Grid.Column="2"
                        Content="Buttress All"
                        Click="ButtressAllButton_Click" />
                <Button x:Name="RemoveButtressingFromSelectedButton"
                        Grid.Row="2"
                        Grid.ColumnSpan="3"
                        Content="Remove Buttressing From Selected"
                        IsEnabled="False"
                        Click="RemoveButtressingFromSelectedButton_Click" />
                <Button x:Name="RemoveAllButtressesButton"
                        Grid.Row="4"
                        Grid.ColumnSpan="3"
                        Content="Remove All Buttresses"
                        IsEnabled="False"
                        Click="RemoveAllButtressesButton_Click" />
            </Grid>

            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,10,0,0"
                       Style="{StaticResource ModeOverlayBodyTextStyle}"
                       TextWrapping="Wrap"
                       Text="No bracing or buttressing has been applied yet." />

            <Button Margin="0,14,0,0"
                    Content="Close"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Border>
</UserControl>
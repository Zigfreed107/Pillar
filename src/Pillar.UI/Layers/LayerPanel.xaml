<!--
    LayerPanel.xaml
    Defines the viewport overlay used to organize imported models and their support groups.
-->
<UserControl x:Class="Pillar.UI.Layers.LayerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             xmlns:viewModels="clr-namespace:Pillar.ViewModels;assembly=Pillar.ViewModels"
             MinWidth="260">

    <UserControl.Resources>
        <Style x:Key="LayerPanelEmptyButtonStyle" TargetType="Button">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasImportedModels}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LayerPanelTreeStyle" TargetType="TreeView">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="MinHeight" Value="120" />
            <Setter Property="MaxHeight" Value="360" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource ControlStrongFillColorDisabledBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasImportedModels}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LayerTreeItemContainerStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type viewModels:LayerTreeItemViewModel}"
                                  ItemsSource="{Binding Children}">
            <Grid MinHeight="24">
                <TextBox x:Name="RenameTextBox"
                         MinWidth="160"
                         Padding="3,1"
                         Visibility="Collapsed"
                         Loaded="RenameTextBox_Loaded"
                         LostFocus="RenameTextBox_LostFocus"
                         KeyDown="RenameTextBox_KeyDown"
                         Text="{Binding EditingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock x:Name="LayerNameTextBlock"
                           VerticalAlignment="Center"
                           Text="{Binding Name}">
                    <TextBlock.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Rename"
                                      IsEnabled="{Binding CanRename}"
                                      Click="RenameSupportGroupMenuItem_Click" />
                        </ContextMenu>
                    </TextBlock.ContextMenu>
                </TextBlock>
            </Grid>

            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter TargetName="RenameTextBox" Property="Visibility" Value="Visible" />
                    <Setter TargetName="LayerNameTextBlock" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource LayerOverlayPanelStyle}">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource ModeOverlayTitleTextStyle}"
                            FontFamily="Segoe Fluent Icons"
                            Text="&#xE81E;"
                            ToolBar.OverflowMode="Never" />
                <TextBlock Margin="10,0,10,0"
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI"
                            Style="{StaticResource ModeOverlayTitleTextStyle}"
                            Text="Layers"
                            ToolBar.OverflowMode="Never" />
            </StackPanel>
            <ToolBarTray DockPanel.Dock="Top"
                         Margin="0,10,0,0"
                         IsLocked="True">
                <ToolBar FontFamily="Segoe Fluent Icons">
                    <ToolBar.Resources>
                        <Style TargetType="{x:Type primitives:Thumb}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Style>
                    </ToolBar.Resources>
                    <Button x:Name="AddModelButton"
                            MinWidth="28"
                            Content="&#xF164;"
                            ToolTip="Import model"
                            Foreground="Green"
                            IsEnabled="{Binding CanAddModel}"
                            Click="AddModelButton_Click"
                            ToolBar.OverflowMode="Never" />
                    <Button x:Name="RemoveModelButton"
                            MinWidth="28"
                            Content="&#xF166;"
                            ToolTip="Remove selected model"
                            Foreground="Red"
                            IsEnabled="{Binding CanRemoveModel}"
                            Click="RemoveModelButton_Click"
                            ToolBar.OverflowMode="Never" />
                    <Separator ToolBar.OverflowMode="Never" />
                    <Button x:Name="AddSupportGroupButton"
                            MinWidth="28"
                            Content="&#xECC8;"
                            FontFamily="Segoe Fluent Icons"
                            ToolTip="Add support group"
                            Foreground="Green"
                            IsEnabled="{Binding CanAddSupportGroup}"
                            Click="AddSupportGroupButton_Click"
                            ToolBar.OverflowMode="Never" />
                    <Button x:Name="RemoveSupportGroupButton"
                            MinWidth="28"
                            Content="&#xECC9;"
                            FontFamily="Segoe Fluent Icons"
                            ToolTip="Remove support group"
                            Foreground="Red"
                            IsEnabled="{Binding CanRemoveSupportGroup}"
                            Click="RemoveSupportGroupButton_Click"
                            ToolBar.OverflowMode="Never" />
                </ToolBar>
            </ToolBarTray>

            <Grid>
                <Button Content="Import a Model"
                        Style="{StaticResource LayerPanelEmptyButtonStyle}"
                        Click="ImportModelButton_Click" />

                <TreeView x:Name="LayerTree"
                          ItemsSource="{Binding ModelLayers}"
                          ItemContainerStyle="{StaticResource LayerTreeItemContainerStyle}"
                          Style="{StaticResource LayerPanelTreeStyle}"
                          SelectedItemChanged="LayerTree_SelectedItemChanged" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>

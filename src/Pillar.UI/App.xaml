<!--
    App.xaml
    Defines application startup and shared WPF resources used by the CAD workspace shell.
-->
<Application x:Class="Pillar.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ThemeMode="Light">
    <Application.Resources>
        <SolidColorBrush x:Key="ModeOverlayBackgroundBrush" Color="#F8FFFFFF" />
        <SolidColorBrush x:Key="ModeOverlayBorderBrush" Color="#66000000" />
        <SolidColorBrush x:Key="ModeOverlayTitleBrush" Color="#FF1F2933" />
        <SolidColorBrush x:Key="ModeOverlayBodyBrush" Color="#FF3E4C59" />
        <SolidColorBrush x:Key="ModeOverlayLabelBrush" Color="#FF007ACC" />
        <Color x:Key="ViewportAmbientLightColor">#FF303030</Color>
        <Color x:Key="ViewportKeyLightColor">#BABABA</Color>
        <Color x:Key="ViewportFillLightColor">#707070</Color>

        <Style x:Key="ModeOverlayPanelStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="260" />
            <Setter Property="MaxWidth" Value="360" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="{StaticResource ModeOverlayBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ModeOverlayBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="ModeOverlayTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ModeOverlayTitleBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ModeOverlayBodyTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource ModeOverlayBodyBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ModeOverlayLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ModeOverlayLabelBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        
        <Style x:Key="LayerOverlayPanelStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="260" />
            <Setter Property="MaxWidth" Value="360" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="{DynamicResource LayerOnMicaBaseAltFillColorTertiaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ModeOverlayBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        
    </Application.Resources>
</Application>

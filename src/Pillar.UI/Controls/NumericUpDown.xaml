<!--
    NumericUpDown.xaml
    Provides a reusable WPF numeric editor for tool settings without introducing third-party UI dependencies.
-->
<UserControl x:Class="Pillar.UI.Controls.NumericUpDown"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             MinWidth="92"
             MinHeight="24"
             Focusable="False">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="24" />
        </Grid.ColumnDefinitions>

        <TextBox x:Name="ValueTextBox"
                 Grid.Column="0"
                 MinHeight="24"
                 Padding="4,1"
                 VerticalContentAlignment="Center"
                 TextChanged="ValueTextBox_TextChanged"
                 LostKeyboardFocus="ValueTextBox_LostKeyboardFocus"
                 PreviewKeyDown="ValueTextBox_PreviewKeyDown" />

        <Grid Grid.Column="1"
              Margin="2,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <primitives:RepeatButton Grid.Row="0"
                                     Style="{x:Null}"
                                     MinWidth="0"
                                     MinHeight="0"
                                     Padding="0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Delay="300"
                                     Interval="70"
                                     Click="IncreaseButton_Click"
                                     Content="+" />
            <primitives:RepeatButton Grid.Row="1"
                                     Style="{x:Null}"
                                     MinWidth="0"
                                     MinHeight="0"
                                     Padding="0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Delay="300"
                                     Interval="70"
                                     Click="DecreaseButton_Click"
                                     Content="-" />
        </Grid>
    </Grid>
</UserControl>

<!--
    MainWindow.xaml
    Defines the CAD workspace shell with viewport overlays, menu, toolbar, and status regions.
-->
<Window x:Class="Pillar.UI.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        xmlns:layers="clr-namespace:Pillar.UI.Layers"
        xmlns:modes="clr-namespace:Pillar.UI.Modes"
        Title="{Binding WindowTitle}"
        Height="1080"
        Width="1920"
        MinHeight="480"
        MinWidth="900"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="SelectionWindowStrokeBrush" Color="#FF007ACC" />
        <SolidColorBrush x:Key="SelectionWindowFillBrush" Color="#22007ACC" />
        <DoubleCollection x:Key="SelectionWindowSolidDashArray" />
        <DoubleCollection x:Key="SelectionWindowDottedDashArray">8,4</DoubleCollection>


        <Style x:Key="SelectionWindowOverlayStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="{StaticResource SelectionWindowFillBrush}" />
            <Setter Property="Stroke" Value="{StaticResource SelectionWindowStrokeBrush}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" >
        <!--Top Menu-->
        <Border DockPanel.Dock="Top"
                MinHeight="48"
                Padding="2,1"
                SnapsToDevicePixels="True">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Menu Grid.Column="0"
                      Height="48"
                      Margin="0"
                      Padding="0"
                      VerticalAlignment="Top">
                    <MenuItem Header="_File"
                              Height="48"
                              Padding="8,0"
                              VerticalContentAlignment="Center">
                        <MenuItem Header="_New"
                                  Click="NewProjectMenuItem_Click" />
                        <MenuItem Header="_Open..."
                                  Click="OpenProjectMenuItem_Click" />
                        <MenuItem Header="_Save..."
                                  Click="SaveProjectMenuItem_Click" />
                        <Separator />
                        <MenuItem Header="Import Model"
                                  Click="ImportStlButton_Click" />
                    </MenuItem>
                    <MenuItem x:Name="UndoButton"
                              Header="&#xE7A7;" 
                              FontFamily="Segoe Fluent Icons" 
                              Click="UndoButton_Click"
                              ToolTip="Undo"/>
                    <MenuItem x:Name="RedoButton"
                              Header="&#xE7A6;" 
                              FontFamily="Segoe Fluent Icons" 
                              Click="RedoButton_Click"
                              ToolTip="Redo"/>

                </Menu>
            </Grid>
        </Border>
        
        <!--Status Bar-->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding StatusText}" />
        </StatusBar>
        
        <!--Everything else inbetween-->
        <Grid Margin="6">
            <Border>
                <Grid>
                    <hx:Viewport3DX x:Name="Viewport"
                                    Background="White"
                                    BackgroundColor="White"
                                    EffectsManager="{Binding ElementName=RootWindow, Path=EffectsManager}"
                                    IsViewCubeEdgeClicksEnabled="True"
                                    ModelUpDirection="0,0,1"
                                    MouseDown="Viewport_MouseDown"
                                    MouseMove="Viewport_MouseMove"
                                    MouseUp="Viewport_MouseUp"
                                    Orthographic="True"
                                    RotateAroundMouseDownPoint="True"
                                    ShowCameraTarget="True"
                                    ShowCoordinateSystem="True"
                                    ShowViewCube="True"
                                    ZoomAroundMouseDownPoint="False"
                                    MSAA="Maximum">

                        <hx:Viewport3DX.Camera>
                            <hx:OrthographicCamera Position="10,10,10"
                                                   LookDirection="-10,-10,-10"
                                                   UpDirection="0,0,1"
                                                   />
                        </hx:Viewport3DX.Camera>

                        <!--
                            Use a small ambient term plus a key and fill directional light.
                            This keeps the model readable from most view angles without flattening the shading.
                        -->
                        <hx:AmbientLight3D Color="{StaticResource ViewportAmbientLightColor}" />
                        <hx:DirectionalLight3D Color="{StaticResource ViewportKeyLightColor}"
                                               Direction="-1,-1,-1" />
                        <hx:DirectionalLight3D Color="{StaticResource ViewportFillLightColor}"
                                               Direction="1,0.35,-0.75" />
                    </hx:Viewport3DX>

                    <Canvas x:Name="ViewportOverlayCanvas"
                            ClipToBounds="True"
                            IsHitTestVisible="False">
                        <Rectangle x:Name="SelectionWindowOverlay"
                                   Style="{StaticResource SelectionWindowOverlayStyle}" />
                    </Canvas>

                    <!--
                        Keep viewport overlay panels anchored independently so workflow controls do not
                        compete with layer management as the tool options panel grows.
                    -->
                    <Grid Margin="12"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          IsHitTestVisible="True"
                          Panel.ZIndex="20">
                        
                        <layers:LayerPanel x:Name="LayerPanelOverlay"
                                           Width="280"
                                           Height="280"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           IsHitTestVisible="True" />

                        <StackPanel Width="360"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    IsHitTestVisible="True">
                             
                            <modes:ModePanel x:Name="WorkflowModePanelOverlay"
                                             Width="360"
                                             Height="Auto"
                                             IsHitTestVisible="True" />

                            <modes:ToolOptionsPanel x:Name="ToolOptionsPanelOverlay"
                                                    Width="360"
                                                    Height="Auto"
                                                    Margin="0,6,0,0"
                                                    Visibility="Collapsed"
                                                    IsHitTestVisible="True" />
                        </StackPanel>
                    </Grid>

                </Grid>
            </Border>

        </Grid>
    </DockPanel>

</Window>

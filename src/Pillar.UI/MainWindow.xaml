<!--
    MainWindow.xaml
    Defines the CAD workspace shell with docked regions for tools, viewer, properties, menu, and status.
-->
<Window x:Class="Pillar.UI.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        xmlns:layers="clr-namespace:Pillar.UI.Layers"
        Title="{Binding WindowTitle}"
        Height="1080"
        Width="1920"
        MinHeight="480"
        MinWidth="900"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="SelectionWindowStrokeBrush" Color="#FF007ACC" />
        <SolidColorBrush x:Key="SelectionWindowFillBrush" Color="#22007ACC" />
        <DoubleCollection x:Key="SelectionWindowSolidDashArray" />
        <DoubleCollection x:Key="SelectionWindowDottedDashArray">8,4</DoubleCollection>

        <Style x:Key="SelectionWindowOverlayStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="{StaticResource SelectionWindowFillBrush}" />
            <Setter Property="Stroke" Value="{StaticResource SelectionWindowStrokeBrush}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" >
        <DockPanel DockPanel.Dock="Top">
            <Menu DockPanel.Dock="Top" >
                <MenuItem Header="_File">
                    <MenuItem Header="_New"
                              Click="NewProjectMenuItem_Click" />
                    <MenuItem Header="_Open..."
                              Click="OpenProjectMenuItem_Click" />
                    <MenuItem Header="_Save..."
                              Click="SaveProjectMenuItem_Click" />
                    <Separator/>
                    <MenuItem Header="Import Model"
                              Click="ImportStlButton_Click" />
                </MenuItem>


            </Menu>

            <ToolBarTray>
                <ToolBar x:Name="MainToolbar" FontFamily="{StaticResource SymbolThemeFontFamily}">
                    <Button x:Name="UndoButton"
                            Content="&#xE7A7;"
                            Click="UndoButton_Click" />
                    <Button x:Name="RedoButton"
                            Content="&#xE7A6;"
                            Click="RedoButton_Click" />
                    <Separator/>
                </ToolBar>
                <ToolBar x:Name="ModeToolbar">
                    <ToggleButton x:Name="SelectMode"
                                  MinWidth="72"
                                  Padding="10,4"
                                  Click="SelectMode_Click"
                                  Content="Select"
                                  ToolTip="Selection mode" />
                    <ToggleButton x:Name="LineMode"
                                  MinWidth="72"
                                  Padding="10,4"
                                  Click="LineMode_Click"
                                  Content="Line"
                                  ToolTip="Line drawing mode" />
                    <ToggleButton x:Name="TransformMode"
                                  MinWidth="88"
                                  Padding="10,4"
                                  Click="TransformMode_Click"
                                  Content="Transform"
                                  ToolTip="Transform mode is planned"
                                  IsEnabled="False" />
                    <ToggleButton x:Name="SupportMode"
                                  MinWidth="88"
                                  Padding="10,4"
                                  Click="SupportMode_Click"
                                  Content="Support"
                                  ToolTip="Support mode is planned"
                                  IsEnabled="False" />
                </ToolBar>
            </ToolBarTray>
        </DockPanel>
        
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding StatusText}" />
        </StatusBar>

        <Grid Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns" />

            <Border Grid.Column="0" >
                <Grid>
                    <hx:Viewport3DX x:Name="Viewport"
                                    Background="White"
                                    BackgroundColor="White"
                                    EffectsManager="{Binding ElementName=RootWindow, Path=EffectsManager}"
                                    IsViewCubeEdgeClicksEnabled="True"
                                    ModelUpDirection="0,0,1"
                                    MouseDown="Viewport_MouseDown"
                                    MouseMove="Viewport_MouseMove"
                                    MouseUp="Viewport_MouseUp"
                                    Orthographic="True"
                                    RotateAroundMouseDownPoint="True"
                                    ShowCameraTarget="True"
                                    ShowCoordinateSystem="True"
                                    ShowFrameDetails="True"
                                    ShowFrameRate="True"
                                    ShowViewCube="True"
                                    ZoomAroundMouseDownPoint="True"
                                    MSAA="Maximum"
                                    ShowTriangleCountInfo="True"
                                    ShowCameraInfo="True">

                        <hx:Viewport3DX.Camera>
                            <hx:OrthographicCamera Position="10,10,10"
                                                   LookDirection="-10,-10,-10"
                                                   UpDirection="0,0,1"
                                                   FarPlaneDistance="10000"
                                                   NearPlaneDistance="0.01"/>
                        </hx:Viewport3DX.Camera>

                        <hx:DirectionalLight3D Direction="-1,-1,-1" />
                    </hx:Viewport3DX>

                    <Canvas x:Name="ViewportOverlayCanvas"
                            ClipToBounds="True"
                            IsHitTestVisible="False">
                        <Rectangle x:Name="SelectionWindowOverlay"
                                   Style="{StaticResource SelectionWindowOverlayStyle}" />
                    </Canvas>

                    <layers:LayerPanel x:Name="LayerPanelOverlay"
                                       Margin="12"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       IsHitTestVisible="True"
                                       Panel.ZIndex="20" />

                    <ContentControl x:Name="ModePanelHost"
                                    Margin="12"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    IsHitTestVisible="True"
                                    Panel.ZIndex="20" />
                </Grid>
            </Border>

            <Border Grid.Column="2" >
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" >
                        <TextBlock Text="{Binding PropertiesPanelTitle}" />
                    </Border>
                    <Grid Margin="12" VerticalAlignment="Top">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding PropertiesPanelText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2"
                                   FontWeight="SemiBold"
                                   Text="{Binding SelectedEntityType}" />

                        <Grid Grid.Row="4"
                              IsEnabled="{Binding IsEntitySelected}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="0,3,8,0"
                                       Text="Name" />
                            <TextBox x:Name="SelectedEntityNameTextBox"
                                     Grid.Column="1"
                                     MinWidth="120"
                                     KeyDown="SelectedEntityNameTextBox_KeyDown"
                                     LostFocus="SelectedEntityNameTextBox_LostFocus"
                                     Text="{Binding SelectedEntityName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>

</Window>

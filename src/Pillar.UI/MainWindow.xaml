<!--
    MainWindow.xaml
    Defines the CAD workspace shell with docked regions for tools, viewer, properties, menu, and status.
-->
<Window x:Class="Pillar.UI.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        Title="{Binding WindowTitle}"
        Height="1080"
        Width="1920"
        MinHeight="480"
        MinWidth="900"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="PaneChromeStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF7F7F7" />
            <Setter Property="BorderBrush" Value="#FFD2D2D2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="PaneHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFECECEC" />
            <Setter Property="BorderBrush" Value="#FFD2D2D2" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style x:Key="PaneHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF2D2D30" />
        </Style>

        <SolidColorBrush x:Key="SelectionWindowStrokeBrush" Color="#FF007ACC" />
        <SolidColorBrush x:Key="SelectionWindowFillBrush" Color="#22007ACC" />
        <DoubleCollection x:Key="SelectionWindowSolidDashArray" />
        <DoubleCollection x:Key="SelectionWindowDottedDashArray">8,4</DoubleCollection>

        <Style x:Key="SelectionWindowOverlayStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="{StaticResource SelectionWindowFillBrush}" />
            <Setter Property="Stroke" Value="{StaticResource SelectionWindowStrokeBrush}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Background="#FFF3F3F3">
        
        <Menu DockPanel.Dock="Top" Background="#FFF5F5F5">
            <MenuItem Header="_File">
                <MenuItem Header="_New"
                          Click="NewProjectMenuItem_Click" />
                <MenuItem Header="_Open..."
                          Click="OpenProjectMenuItem_Click" />
                <MenuItem Header="_Save..."
                          Click="SaveProjectMenuItem_Click" />
            </MenuItem>
            <MenuItem Header="_Edit" />
            <MenuItem Header="_View" />
            <MenuItem Header="_Tools" />
            <MenuItem Header="_Window" />
            <MenuItem Header="_Help" />
        </Menu>

        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
            <ToolBar x:Name="MainToolbar" Background="#FFF5F5F5">
                <Button x:Name="UndoButton"
                        Content="Undo"
                        Click="UndoButton_Click" />
                <Button x:Name="RedoButton"
                        Content="Redo"
                        Click="RedoButton_Click" />
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding StatusText}" />
        </StatusBar>

        <Grid Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PaneChromeStyle}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Style="{StaticResource PaneHeaderStyle}">
                        <TextBlock Style="{StaticResource PaneHeaderTextStyle}" Text="{Binding ToolPanelTitle}" />
                    </Border>
                    <StackPanel Margin="12" VerticalAlignment="Top">
                        <Button Margin="0,0,0,8"
                                Padding="10,6"
                                Click="SelectToolButton_Click"
                                Content="Select" />
                        <Button Margin="0,0,0,12"
                                Padding="10,6"
                                Click="LineToolButton_Click"
                                Content="Line" />
                        <Button Margin="0,0,0,12"
                                Padding="10,6"
                                Click="ImportStlButton_Click"
                                Content="Import STL" />
                        <TextBlock Text="{Binding ToolPanelText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#FFDADADA"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns" />

            <Border Grid.Column="2" Style="{StaticResource PaneChromeStyle}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Style="{StaticResource PaneHeaderStyle}">
                        <TextBlock Style="{StaticResource PaneHeaderTextStyle}" Text="{Binding ViewerTitle}" />
                    </Border>

                    <Grid>
                        <hx:Viewport3DX x:Name="Viewport"
                                        Background="White"
                                        BackgroundColor="White"
                                        EffectsManager="{Binding ElementName=RootWindow, Path=EffectsManager}"
                                        IsViewCubeEdgeClicksEnabled="True"
                                        ModelUpDirection="0,0,1"
                                        MouseDown="Viewport_MouseDown"
                                        MouseMove="Viewport_MouseMove"
                                        MouseUp="Viewport_MouseUp"
                                        Orthographic="True"
                                        RotateAroundMouseDownPoint="True"
                                        ShowCoordinateSystem="True"
                                        ShowFrameDetails="True"
                                        ShowFrameRate="True"
                                        ShowViewCube="True"
                                        ZoomAroundMouseDownPoint="True"
                                        MSAA="Maximum" ShowTriangleCountInfo="True" ShowCameraInfo="True">

                            <hx:Viewport3DX.Camera>
                                <hx:OrthographicCamera Position="10,10,10"
                                                       LookDirection="-10,-10,-10"
                                                       UpDirection="0,0,1" 
                                                       FarPlaneDistance="10000"
                                                       NearPlaneDistance="0.1"
 />
                            </hx:Viewport3DX.Camera>

                            <hx:DirectionalLight3D Direction="-1,-1,-1" />
                        </hx:Viewport3DX>

                        <Canvas x:Name="ViewportOverlayCanvas"
                                ClipToBounds="True"
                                IsHitTestVisible="False">
                            <Rectangle x:Name="SelectionWindowOverlay"
                                       Style="{StaticResource SelectionWindowOverlayStyle}" />
                        </Canvas>
                    </Grid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#FFDADADA"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns" />

            <Border Grid.Column="4" Style="{StaticResource PaneChromeStyle}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Style="{StaticResource PaneHeaderStyle}">
                        <TextBlock Style="{StaticResource PaneHeaderTextStyle}" Text="{Binding PropertiesPanelTitle}" />
                    </Border>
                    <Grid Margin="12" VerticalAlignment="Top">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding PropertiesPanelText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2"
                                   FontWeight="SemiBold"
                                   Text="{Binding SelectedEntityType}" />

                        <Grid Grid.Row="4"
                              IsEnabled="{Binding IsEntitySelected}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="0,3,8,0"
                                       Text="Name" />
                            <TextBox x:Name="SelectedEntityNameTextBox"
                                     Grid.Column="1"
                                     MinWidth="120"
                                     KeyDown="SelectedEntityNameTextBox_KeyDown"
                                     LostFocus="SelectedEntityNameTextBox_LostFocus"
                                     Text="{Binding SelectedEntityName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>

</Window>

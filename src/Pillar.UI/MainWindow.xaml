<!--
    MainWindow.xaml
    Defines the CAD workspace shell with viewport overlays, menu, toolbar, and status regions.
-->
<Window x:Class="Pillar.UI.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Pillar.UI.Controls"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        xmlns:layers="clr-namespace:Pillar.UI.Layers"
        xmlns:modes="clr-namespace:Pillar.UI.Modes"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="{Binding WindowTitle}"
        Height="1080"
        Width="1920"
        MinHeight="480"
        MinWidth="900"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">

    <Window.Resources>
        <SolidColorBrush x:Key="SelectionWindowStrokeBrush" Color="#FF007ACC" />
        <SolidColorBrush x:Key="SelectionWindowFillBrush" Color="#22007ACC" />
        <DoubleCollection x:Key="SelectionWindowSolidDashArray" />
        <DoubleCollection x:Key="SelectionWindowDottedDashArray">8,4</DoubleCollection>


        <Style x:Key="SelectionWindowOverlayStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="{StaticResource SelectionWindowFillBrush}" />
            <Setter Property="Stroke" Value="{StaticResource SelectionWindowStrokeBrush}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" >
        <!--Top Menu-->
        <Border DockPanel.Dock="Top"
                MinHeight="48"
                Padding="2,1"
                SnapsToDevicePixels="True">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Menu Grid.Column="0"
                      Height="48"
                      Margin="0"
                      Padding="0"
                      VerticalAlignment="Top">
                    <MenuItem Header="_File"
                              Height="48"
                              Padding="8,0"
                              VerticalContentAlignment="Center">
                        <MenuItem Header="_New"
                                  Click="NewProjectMenuItem_Click" />
                        <MenuItem Header="_Open..."
                                  Click="OpenProjectMenuItem_Click" />
                        <MenuItem Header="_Save..."
                                  Click="SaveProjectMenuItem_Click" />
                        <Separator />
                        <MenuItem Header="Import Model"
                                  Click="ImportStlButton_Click" />
                    </MenuItem>
                    <MenuItem x:Name="UndoButton"
                              Header="&#xE7A7;"
                              FontFamily="Segoe Fluent Icons"
                              Click="UndoButton_Click"
                              ToolTip="Undo"/>
                    <MenuItem x:Name="RedoButton"
                              Header="&#xE7A6;"
                              FontFamily="Segoe Fluent Icons"
                              Click="RedoButton_Click"
                              ToolTip="Redo"/>

                </Menu>

                <StackPanel Grid.Column="1"
                            Margin="12,0,0,0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ToggleButton x:Name="FaceAngleHighlightToggleButton"
                                      Grid.Column="0"
                                      MinHeight="28"
                                      Padding="8,2"
                                      VerticalAlignment="Center"
                                      Content="Highlight shallow faces"
                                      Checked="FaceAngleHighlightToggleButton_Changed"
                                      Unchecked="FaceAngleHighlightToggleButton_Changed"
                                      ToolTip="Highlight model faces within the selected angle from the XY build plate." />

                        <ToggleButton x:Name="FaceAngleHighlightDropDownButton"
                                      Grid.Column="1"
                                      Width="26"
                                      MinHeight="28"
                                      Margin="2,0,0,0"
                                      Padding="0"
                                      VerticalAlignment="Center"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      Content="&#xE70D;"
                                      FontFamily="Segoe Fluent Icons"
                                      PreviewMouseDown="FaceAngleHighlightDropDownButton_PreviewMouseDown"
                                      Click="FaceAngleHighlightDropDownButton_Click"
                                      ToolTip="Shallow face highlight settings" />

                        <primitives:Popup x:Name="FaceAngleHighlightSettingsPopup"
                                          AllowsTransparency="True"
                                          Placement="Bottom"
                                          PlacementTarget="{Binding ElementName=FaceAngleHighlightDropDownButton}"
                                          StaysOpen="False"
                                          Closed="FaceAngleHighlightSettingsPopup_Closed">
                            <Border MinWidth="170"
                                    Padding="10"
                                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,6"
                                               Text="Angle" />
                                    <DockPanel LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="&#x00B0;" />
                                        <controls:NumericUpDown x:Name="FaceAngleThresholdNumericUpDown"
                                                                Width="96"
                                                                Minimum="1"
                                                                Maximum="90"
                                                                Increment="1"
                                                                DecimalPlaces="0"
                                                                Value="45"
                                                                ValueChanged="FaceAngleThresholdNumericUpDown_ValueChanged" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </primitives:Popup>
                    </Grid>

                    <Border Width="1"
                            Height="24"
                            Margin="12,0"
                            Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" />

                    <Button x:Name="FaceSetSelectionLaunchButton"
                            MinHeight="28"
                            Margin="0,0,12,0"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            Content="Face Select"
                            Click="FaceSetSelectionLaunchButton_Click"
                            ToolTip="Open the temporary face set selection helper." />

                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ToggleButton x:Name="ScaledCursorToggleButton"
                                      Grid.Column="0"
                                      MinHeight="28"
                                      Padding="8,2"
                                      VerticalAlignment="Center"
                                      Content="Scaled Cursor"
                                      Checked="ScaledCursorToggleButton_Changed"
                                      Unchecked="ScaledCursorToggleButton_Changed"
                                      ToolTip="Show a scaled guide circle on the build plate under the cursor." />

                        <ToggleButton x:Name="ScaledCursorDropDownButton"
                                      Grid.Column="1"
                                      Width="26"
                                      MinHeight="28"
                                      Margin="2,0,0,0"
                                      Padding="0"
                                      VerticalAlignment="Center"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      Content="&#xE70D;"
                                      FontFamily="Segoe Fluent Icons"
                                      PreviewMouseDown="ScaledCursorDropDownButton_PreviewMouseDown"
                                      Click="ScaledCursorDropDownButton_Click"
                                      ToolTip="Scaled cursor settings" />

                        <primitives:Popup x:Name="ScaledCursorSettingsPopup"
                                          AllowsTransparency="True"
                                          Placement="Bottom"
                                          PlacementTarget="{Binding ElementName=ScaledCursorDropDownButton}"
                                          StaysOpen="False"
                                          Closed="ScaledCursorSettingsPopup_Closed">
                            <Border MinWidth="190"
                                    Padding="10"
                                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,6"
                                               Text="Circle diameter" />
                                    <DockPanel LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="mm" />
                                        <controls:NumericUpDown x:Name="ScaledCursorDiameterNumericUpDown"
                                                                Width="116"
                                                                Minimum="0.10"
                                                                Maximum="500.00"
                                                                Increment="0.50"
                                                                DecimalPlaces="2"
                                                                ValueChanged="ScaledCursorDiameterNumericUpDown_ValueChanged" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </primitives:Popup>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!--Status Bar-->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding StatusText}" />
        </StatusBar>

        <!--Everything else inbetween-->
        <Grid Margin="6">
            <Border>
                <Grid>
                    <hx:Viewport3DX x:Name="Viewport"
                                    Background="White"
                                    BackgroundColor="White"
                                    EffectsManager="{Binding ElementName=RootWindow, Path=EffectsManager}"
                                    IsViewCubeEdgeClicksEnabled="True"
                                    ModelUpDirection="0,0,1"
                                    MouseDown="Viewport_MouseDown"
                                    MouseLeave="Viewport_MouseLeave"
                                    MouseMove="Viewport_MouseMove"
                                    MouseUp="Viewport_MouseUp"
                                    Orthographic="True"
                                    RotateAroundMouseDownPoint="True"
                                    ShowCameraTarget="True"
                                    ShowCoordinateSystem="True"
                                    ShowViewCube="True"
                                    MSAA="Disable"
                                    FXAALevel="Ultra"
                                    EnableSSAO="True"
                                    SSAOQuality="High"
                                    SSAOSamplingRadius="8.0"
                                    SSAOIntensity="4">

                        <hx:Viewport3DX.Camera>
                            <hx:OrthographicCamera Position="10,10,10"
                                                   LookDirection="-10,-10,-10"
                                                   UpDirection="0,0,1"
                                                   />
                        </hx:Viewport3DX.Camera>

                        <!--
                            Use a small ambient term plus a key and fill directional light.
                            This keeps the model readable from most view angles without flattening the shading.
                        -->
                        <hx:AmbientLight3D Color="{StaticResource ViewportAmbientLightColor}" />
                        <hx:DirectionalLight3D Color="{StaticResource ViewportKeyLightColor}"
                                               Direction="-1,-1,-1" />
                        <hx:DirectionalLight3D Color="{StaticResource ViewportFillLightColor}"
                                               Direction="1,1,1" />
                    </hx:Viewport3DX>

                    <Canvas x:Name="ViewportOverlayCanvas"
                            ClipToBounds="True"
                            IsHitTestVisible="False">
                        <Rectangle x:Name="SelectionWindowOverlay"
                                   Style="{StaticResource SelectionWindowOverlayStyle}" />
                        <Line x:Name="FaceSetLineSelectionPreview"
                              Stroke="{StaticResource SelectionWindowStrokeBrush}"
                              StrokeThickness="2"
                              StrokeDashArray="6,3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Visibility="Collapsed"
                              IsHitTestVisible="False" />
                    </Canvas>

                    <!--
                        Keep viewport overlay panels anchored independently so workflow controls do not
                        compete with layer management as the tool options panel grows.
                    -->
                    <Grid Margin="12"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          IsHitTestVisible="True"
                          Panel.ZIndex="20">

                        <Grid Width="280"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Stretch"
                              IsHitTestVisible="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <layers:LayerPanel x:Name="LayerPanelOverlay"
                                               Grid.Row="0"
                                               Width="280"
                                               Height="280"
                                               IsHitTestVisible="True" />

                            <controls:ClipRangeSlider x:Name="ClipRangeSliderOverlay"
                                                      Grid.Row="1"
                                                      Width="96"
                                                      Margin="0,8,0,0"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Stretch"
                                                      IsHitTestVisible="True" />
                        </Grid>

                        <StackPanel Width="360"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    IsHitTestVisible="True">

                            <modes:ModePanel x:Name="WorkflowModePanelOverlay"
                                             Width="360"
                                             Height="Auto"
                                             IsHitTestVisible="True" />

                            <ContentControl x:Name="ToolOptionsHostOverlay"
                                            Width="360"
                                            Height="Auto"
                                            Margin="0,6,0,0"
                                            Visibility="Collapsed"
                                            IsHitTestVisible="True" />

                            <modes:SupportPresetPanel x:Name="SupportPresetPanelOverlay"
                                                      Width="360"
                                                      Height="Auto"
                                                      Margin="0,6,0,0"
                                                      Visibility="Collapsed"
                                                      IsHitTestVisible="True" />
                        </StackPanel>

                        <ContentControl x:Name="FaceSetSelectionToolHostOverlay"
                                        Width="420"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Visibility="Collapsed"
                                        IsHitTestVisible="True" />
                    </Grid>

                </Grid>
            </Border>

        </Grid>
    </DockPanel>

</Window>

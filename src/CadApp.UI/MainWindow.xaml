<Window x:Class="CadApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        Title="CadApp" Height="600" Width="900">

    <Grid>
        <hx:Viewport3DX x:Name="Viewport"
                Background="White"
                ShowCoordinateSystem="True"
                ShowViewCube="True" 
                EffectsManager="{Binding EffectsManager}" 
                ShowCameraInfo="True" ShowFrameDetails="True" 
                ShowFrameRate="True" ZoomAroundMouseDownPoint="True" 
                IsViewCubeEdgeClicksEnabled="True" 
                BackgroundColor="White"
                ModelUpDirection="0,0,1"
                MouseDown="Viewport_MouseDown" 
                MouseMove="Viewport_MouseMove" RotateAroundMouseDownPoint="True" Orthographic="True" MSAA="Maximum">

            <hx:Viewport3DX.Camera>
                <hx:OrthographicCamera Position="10,10,10"
                           LookDirection="-10,-10,-10"
                           UpDirection="0,0,1"/>
            </hx:Viewport3DX.Camera>

            <hx:DirectionalLight3D Direction="-1,-1,-1"/>
        </hx:Viewport3DX>
    </Grid>

</Window>

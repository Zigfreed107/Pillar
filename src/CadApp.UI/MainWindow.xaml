<!--
    MainWindow.xaml
    Defines the CAD workspace shell with docked regions for tools, viewer, properties, menu, and status.
-->
<Window x:Class="CadApp.UI.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        Title="{Binding WindowTitle}"
        Height="720"
        Width="1280"
        MinHeight="480"
        MinWidth="900">

    <Window.Resources>
        <Style x:Key="PaneChromeStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF7F7F7" />
            <Setter Property="BorderBrush" Value="#FFD2D2D2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="PaneHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFECECEC" />
            <Setter Property="BorderBrush" Value="#FFD2D2D2" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style x:Key="PaneHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF2D2D30" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Background="#FFF3F3F3">
        <Menu DockPanel.Dock="Top" Background="#FFF5F5F5">
            <MenuItem Header="_File" />
            <MenuItem Header="_Edit" />
            <MenuItem Header="_View" />
            <MenuItem Header="_Tools" />
            <MenuItem Header="_Window" />
            <MenuItem Header="_Help" />
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PaneChromeStyle}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Style="{StaticResource PaneHeaderStyle}">
                        <TextBlock Style="{StaticResource PaneHeaderTextStyle}" Text="{Binding ToolPanelTitle}" />
                    </Border>
                    <TextBlock Margin="12"
                               VerticalAlignment="Top"
                               Text="{Binding ToolPanelText}" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#FFDADADA"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns" />

            <Border Grid.Column="2" Style="{StaticResource PaneChromeStyle}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Style="{StaticResource PaneHeaderStyle}">
                        <TextBlock Style="{StaticResource PaneHeaderTextStyle}" Text="{Binding ViewerTitle}" />
                    </Border>

                    <hx:Viewport3DX x:Name="Viewport"
                                    Background="White"
                                    BackgroundColor="White"
                                    EffectsManager="{Binding ElementName=RootWindow, Path=EffectsManager}"
                                    IsViewCubeEdgeClicksEnabled="True"
                                    ModelUpDirection="0,0,1"
                                    MouseDown="Viewport_MouseDown"
                                    MouseMove="Viewport_MouseMove"
                                    Orthographic="True"
                                    RotateAroundMouseDownPoint="True"
                                    ShowCameraInfo="True"
                                    ShowCoordinateSystem="True"
                                    ShowFrameDetails="True"
                                    ShowFrameRate="True"
                                    ShowViewCube="True"
                                    ZoomAroundMouseDownPoint="True"
                                    MSAA="Maximum">

                        <hx:Viewport3DX.Camera>
                            <hx:OrthographicCamera Position="10,10,10"
                                                   LookDirection="-10,-10,-10"
                                                   UpDirection="0,0,1" />
                        </hx:Viewport3DX.Camera>

                        <hx:DirectionalLight3D Direction="-1,-1,-1" />
                    </hx:Viewport3DX>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#FFDADADA"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns" />

            <Border Grid.Column="4" Style="{StaticResource PaneChromeStyle}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Style="{StaticResource PaneHeaderStyle}">
                        <TextBlock Style="{StaticResource PaneHeaderTextStyle}" Text="{Binding PropertiesPanelTitle}" />
                    </Border>
                    <TextBlock Margin="12"
                               VerticalAlignment="Top"
                               Text="{Binding PropertiesPanelText}" />
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>

</Window>
